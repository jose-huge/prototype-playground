# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# files that may contain secrets / API keys / tokens
*secret*
*token*
*api_key*
*apikey*
*.key
# …but never ignore actual source files in app/ or components/
!app/**
!components/**

# generated per-project files (do not commit)
src/styles/tokens.css
src/docs/design.md
src/docs/tokens.json
docs/design.md
docs/import-meta.json
docs/tokens.json
styles/generated-tokens.css

# built components — generated per-project, never committed to the blank starter
# components/index.ts (the blank barrel) IS committed; individual components are not
components/*.tsx
components/*.module.css

# auto-generated preview routes — recreated on every /api/components scan
app/preview/component/

# machine-specific Claude settings (allowlists, local paths — never commit)
.claude/settings.local.json

# local Figma credentials (machine-specific, never commit)
.figma-config.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
